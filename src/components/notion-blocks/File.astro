---
import * as interfaces from '../../lib/interfaces'
import { filePath } from '../../lib/blog-helpers'
import Caption from './Caption.astro'

export interface Props {
  block: interfaces.Block
}

const { block } = Astro.props

let url: URL | null = null
try {
  url = new URL(block.File?.External?.Url || block.File?.File?.Url)
} catch (err) {
  console.error(`Invalid file URL. error: ${err}`)
}

const filename = url ? decodeURIComponent(url.pathname.split('/').slice(-1)[0]) : ''
const href = url ? (block.File.External ? url.toString() : filePath(url)) : ''
---

<div class="file">
  <div>
    {
      url && (
        <a href={href} target="_blank" rel="noopener noreferrer">
          <img
            src="https://www.notion.so/icons/document_gray.svg"
            alt=""
            loading="lazy"
          />
          <span>{filename}</span>
        </a>
      )
    }
  </div>
  <Caption richTexts={block.File.Caption} />
</div>

<style>
  .file a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 100%;
    padding: 0.45rem 0.55rem;
    border-radius: var(--radius);
    color: var(--fg);
    font-weight: 500;
    line-height: 1.4rem;
    text-decoration: none;
  }

  .file a:hover {
    background-color: rgba(235, 236, 237, 0.7);
  }

  .file a img {
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .file a span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
