---
import * as interfaces from '../../lib/interfaces.ts'
import { isAmazonURL, isGitHubURL } from '../../lib/blog-helpers.ts'
import GitHubLinkPreview from './GitHubLinkPreview.astro'
import Caption from './Caption.astro'

export interface Props {
  block: interfaces.Block
  urlMap: { [key: string]: string }
}

const { block, urlMap } = Astro.props

const urlString = (block.Bookmark || block.LinkPreview || block.Embed).Url

let url: URL | null = null
try {
  url = new URL(urlString)
} catch (err) {
  console.log(err)
}

const decodeEntities = (value = '') =>
  value
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .trim()

const getAttr = (tag: string, attr: string) => {
  const pattern = new RegExp(`${attr}=["']([^"']*)["']`, 'i')
  return tag.match(pattern)?.[1] || ''
}

const findMeta = (html: string, keys: string[]) => {
  const tags = html.match(/<meta\s+[^>]*>/gi) || []
  for (const tag of tags) {
    const name = getAttr(tag, 'name') || getAttr(tag, 'property') || getAttr(tag, 'itemprop')
    if (keys.includes(name.toLowerCase())) {
      const content = getAttr(tag, 'content')
      if (content) return decodeEntities(content)
    }
  }
  return ''
}

const findTitle = (html: string) => {
  const title = findMeta(html, ['og:title', 'twitter:title'])
  if (title) return title

  const match = html.match(/<title[^>]*>([\s\S]*?)<\/title>/i)
  return decodeEntities(match?.[1] || '')
}

const findImage = (html: string, baseUrl: URL) => {
  const image = findMeta(html, ['og:image', 'twitter:image', 'twitter:image:src'])
  if (!image) return ''

  try {
    return new URL(image, baseUrl).toString()
  } catch {
    return image
  }
}

let metadata = { title: '', description: '', image: '' }
if (url && !isAmazonURL(url)) {
  const html = urlMap[url.toString()]
  if (html) {
    metadata = {
      title: findTitle(html),
      description: findMeta(html, ['og:description', 'description', 'twitter:description']),
      image: findImage(html, url),
    }
  }
}

const title = metadata.title || url?.hostname || ''
const description = metadata.description || url?.toString() || ''
---

{
  url &&
    (block.LinkPreview && isGitHubURL(url) ? (
      <GitHubLinkPreview url={url} />
    ) : isAmazonURL(url) ? (
      <div class="no-metadata">
        <a href={url.toString()} target="_blank" rel="noopener noreferrer">
          {url.toString()}
        </a>
      </div>
    ) : (
      <div class="bookmark">
        <a href={url.toString()} target="_blank" rel="noopener noreferrer">
          <div>
            <div>{title}</div>
            <div>{description}</div>
            <div>
              <div>
                <img
                  src={'https://www.google.com/s2/favicons?domain=' + url.hostname}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div>{url.origin}</div>
            </div>
          </div>
          <div class:list={[!metadata.image && 'empty']}>
            {
              metadata.image && (
                <img src={metadata.image} alt="" loading="lazy" decoding="async" />
              )
            }
          </div>
        </a>
        <Caption richTexts={block.Bookmark?.Caption ?? []} />
      </div>
    ))
}

<style>
  .no-metadata > a {
    border-bottom: 0.05em solid;
    border-color: var(--anchor-border, currentColor);
    opacity: 0.7;
  }

  .bookmark {
    display: block;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    font-size: 0.9rem;
  }

  .bookmark > a {
    width: 100%;
    box-sizing: border-box;
    text-decoration: none !important;
    border: 1px solid rgba(55, 53, 47, 0.16);
    border-radius: 4px;
    display: flex;
    overflow: hidden;
    user-select: none;
    background: rgba(255, 255, 255, 0.65);
  }

  .bookmark > a:hover {
    background: rgba(247, 246, 243, 0.75);
  }

  .bookmark > a > div:first-child {
    flex: 4 1 180px;
    padding: 12px 14px 14px;
    overflow: hidden;
    text-align: left;
    color: var(--fg);
  }

  .bookmark > a > div:first-child > div:first-child {
    width: 120px;
    min-width: 100%;
    font-size: 14px;
    line-height: 20px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 24px;
    margin-bottom: 2px;
  }

  .bookmark > a > div:first-child > div:nth-child(2) {
    font-size: 12px;
    line-height: 16px;
    opacity: 0.8;
    height: 32px;
    overflow: hidden;
  }

  .bookmark > a > div:first-child > div:last-child {
    display: flex;
    margin-top: 6px;
  }

  .bookmark > a > div:first-child > div:last-child > div:first-child {
    width: 16px;
    height: 16px;
    min-width: 16px;
    margin-right: 6px;
  }

  .bookmark > a > div:first-child > div:last-child > div:first-child > img {
    max-width: 100%;
    display: inline-block;
  }

  .bookmark > a > div:first-child > div:last-child > div:last-child {
    font-size: 12px;
    line-height: 16px;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bookmark > a > div:last-child {
    flex: 1 1 180px;
    position: relative;
    min-height: 96px;
    background: rgba(247, 246, 243, 0.8);
  }

  .bookmark > a > div:last-child.empty {
    display: none;
  }

  @media (max-width: 640px) {
    .bookmark > a > div:last-child {
      display: none;
    }
  }

  .bookmark > a > div:last-child > img {
    position: absolute !important;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
