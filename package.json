{
  "name": "astro-notion-blog",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "22.16.0",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:cached": "npm run cache:fetch && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .js,.ts,.astro src",
    "format": "npx prettier --write .",
    "cache:fetch": "node scripts/blog-contents-cache.cjs",
    "cache:purge": "nx reset && rm -f tmp/*",
    "_fetch-notion-blocks": "node scripts/retrieve-block-children.cjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.11",
    "@notionhq/client": "^2.2.3",
    "@supercharge/promise-pool": "^3.2.0",
    "astro": "^5.1.3",
    "katex": "^0.16.19",
    "mermaid": "^11.4.1",
    "node-fetch": "^3.3.0",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@nrwl/nx-cloud": "^19.1.0",
    "@types/js-base64": "^3.3.1",
    "@types/katex": "^0.16.7",
    "@types/node-fetch": "^2.6.2",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cli-progress": "^3.12.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.6.0",
    "nx": "20.3.1"
  },
  "nx": {
    "targets": {
      "_fetch-notion-blocks": {
        "inputs": [
          "!{projectRoot}/**/*",
          "!{projectRoot}/**/.*",
          "!{projectRoot}/**/.*/**/*",
          {
            "env": "DATABASE_ID"
          }
        ],
        "outputs": [
          "{projectRoot}/tmp"
        ]
      }
    },
    "includedScripts": [
      "_fetch-notion-blocks"
    ]
  }
}
